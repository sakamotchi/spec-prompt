{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDDesk",
  "version": "0.3.3",
  "identifier": "io.github.sakamotchi.sddesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SDDesk",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "devtools": true,
        "dragDropEnabled": true,
        "tabbingIdentifier": "SDDesk"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
