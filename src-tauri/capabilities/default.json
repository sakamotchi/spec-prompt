{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "SpecPrompt default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:read-all",
    "fs:write-all",
    { "identifier": "fs:allow-watch", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-unwatch", "allow": [{ "path": "**" }] },
    "dialog:default"
  ]
}
